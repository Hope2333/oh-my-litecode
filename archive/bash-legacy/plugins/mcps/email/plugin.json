{
  "name": "email",
  "version": "0.2.0",
  "type": "mcp",
  "description": "Email MCP service - Send and manage emails",
  "author": "OML Team",
  "license": "MIT",
  "platforms": ["termux", "gnu-linux"],
  "dependencies": ["bash"],
  "commands": [
    {"name": "send_email", "description": "Send email", "handler": "main.sh send_email"},
