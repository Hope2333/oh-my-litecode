{
  "name": "security-scan",
  "version": "0.2.0",
  "type": "skill",
  "description": "Security scan skill - Scan for vulnerabilities, report issues, suggest fixes",
  "author": "OML Team",
  "license": "MIT",
  "platforms": ["termux", "gnu-linux"],
  "dependencies": ["bash"],
  "commands": [
    {
      "name": "scan_vulnerabilities",
      "description": "Scan code for vulnerabilities",
      "handler": "main.sh scan_vulnerabilities"
    },
    {
      "name": "report_issues",
      "description": "Report security issues",
      "handler": "main.sh report_issues"
    },
    {
      "name": "suggest_fixes",
      "description": "Suggest security fixes",
      "handler": "main.sh suggest_fixes"
    }
  ],
  "capabilities": {
    "vulnerabilityScanning": true,
    "issueReporting": true,
    "fixSuggestions": true,
    "securityAuditing": true
  }
}
