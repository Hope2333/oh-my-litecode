_oml_platform_label() {
    if [[ -d "/data/data/com.termux/files/usr" ]]; then
        echo "termux"
    else
        echo "gnu-linux"
    fi
}

_require_oct_repo() {
    if [[ ! -d "$OML_OCT_DIR" ]]; then
        echo -e "${RED}Error: opencode-termux repo not found: $OML_OCT_DIR${NC}"
        echo "Set OML_OCT_DIR to your opencode-termux path."
        return 1
    fi
    return 0
}

_require_oct_plugins_repo() {
    if [[ ! -d "$OML_OCT_PLUGINS_DIR" ]]; then
        echo -e "${RED}Error: plugin builder repo not found: $OML_OCT_PLUGINS_DIR${NC}"
        return 1
    fi
    return 0
}

_cmd_opencode_plugin_catalog() {
    _require_oct_plugins_repo || return 1
    local latest=false
    local json=false
    local plain=false
    local no_color=false
    local plugin=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --latest) latest=true; shift ;;
            --json) json=true; shift ;;
            --plain) plain=true; shift ;;
            --no-color) no_color=true; shift ;;
            --plugin) plugin="$2"; shift 2 ;;
            *) echo -e "${YELLOW}warn: unknown arg: $1${NC}"; shift ;;
        esac
    done

    local cmd=(python3 "$OML_OCT_PLUGINS_DIR/tools/plugin-catalog.py" "$OML_OCT_PLUGINS_DIR")
    [[ "$latest" == true ]] && cmd+=(--latest)
    [[ "$json" == true ]] && cmd+=(--json)
    [[ "$plain" == true ]] && cmd+=(--plain)
    [[ "$no_color" == true ]] && cmd+=(--no-color)
    [[ -n "$plugin" ]] && cmd+=(--plugin "$plugin")
    "${cmd[@]}"
}

_cmd_opencode_plugin_build() {
    _require_oct_plugins_repo || return 1
    local plugin="omo"
    local mode="source"
    local odir=""
    local mix="0"
    local list_only=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --plugin) plugin="$2"; shift 2 ;;
            --mode) mode="$2"; shift 2 ;;
            --odir) odir="$2"; shift 2 ;;
            --mix) mix="1"; shift ;;
            --list) list_only=true; shift ;;
            *) echo -e "${YELLOW}warn: unknown arg: $1${NC}"; shift ;;
        esac
    done

    if [[ "$list_only" == true ]]; then
        _cmd_opencode_plugin_catalog
        return 0
    fi

    local resolved
    resolved="$("$OML_OCT_PLUGINS_DIR/tools/resolve-plugin-dir.sh" "$plugin" "$OML_OCT_PLUGINS_DIR")"
    if [[ -z "$resolved" ]]; then
        echo -e "${RED}Error: unknown plugin key: $plugin${NC}"
        echo -e "${BLUE}[oml] available plugins:${NC}"
        _cmd_opencode_plugin_catalog --plain
        return 1
    fi

    local build_cmd=(make -C "$OML_OCT_PLUGINS_DIR" all "PLUGIN=$plugin" "MODE=$mode" "MIX=$mix")
    [[ -n "$odir" ]] && build_cmd+=("ODIR=$odir")

    if "${build_cmd[@]}"; then
        return 0
    fi

    echo -e "${YELLOW}[oml] direct build failed; retrying with local proxy 127.0.0.1:7890${NC}"
    http_proxy="http://127.0.0.1:7890" \
    https_proxy="http://127.0.0.1:7890" \
    all_proxy="socks5h://127.0.0.1:7890" \
    "${build_cmd[@]}"
}

