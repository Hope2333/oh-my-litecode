            ;;
        doctor)
            echo -e "${BLUE}OML Health Check${NC}"
            echo ""
            echo "Platform:"
            echo "  OS: $(oml_platform_detect)"
            echo "  Arch: $(oml_arch)"
            echo ""
            echo "Dependencies:"
            local deps_check
            deps_check="$(oml_check_deps bash python3 git nodejs 2>&1 || true)"
            if [[ "$deps_check" == "ok" ]]; then
                echo "  ✓ All dependencies installed"
            else
                echo "  ✗ ${deps_check#missing:}"
            fi
            echo ""
            echo "Configuration:"
            local config_dir
            config_dir="$(oml_config_dir)"
            if [[ -d "$config_dir" ]]; then
                echo "  ✓ Config directory exists: $config_dir"
            else
                echo "  ✗ Config directory not found"
            fi
            echo ""
            echo "Plugins:"
            if [[ -d "${OML_PLUGINS}" ]]; then
                local plugin_count
                plugin_count="$(find "${OML_PLUGINS}" -name "plugin.json" 2>/dev/null | wc -l)"
                echo "  ✓ Plugin directory exists: ${plugin_count} plugins found"
            else
                echo "  ✗ Plugin directory not found"
            fi
            ;;
        *)
            echo "Unknown platform action: $action"
            return 1
            ;;
    esac
}

# Plugin management command
_cmd_plugins() {
    local action="${1:-list}"
    shift || true
    
    case "$action" in
        list)
            oml_plugins_list "$@"
            ;;
        install)
            oml_plugin_install "$@"
            ;;
        enable)
            oml_plugin_enable "$@"
            ;;
        disable)
            oml_plugin_disable "$@"
            ;;
        run)
            oml_plugin_run "$@"
            ;;
        info)
            oml_plugin_info "$@"
            ;;
        create)
            oml_plugin_create "$@"
            ;;
        help|--help|-h)
            oml_plugins_list help
            ;;
        *)
            echo "Unknown plugin action: $action"
            echo "Use 'oml plugins help' for usage"
            return 1
            ;;
    esac
}

# Qwen agent command (qwenx compatibility)
_cmd_qwen() {
    local qwen_plugin_dir="${OML_PLUGINS}/agents/qwen"
    
    if [[ ! -d "$qwen_plugin_dir" ]]; then
        echo -e "${RED}Error: Qwen plugin not found${NC}"
        echo "Install it with: oml plugins enable qwen"
        return 1
    fi
    
    # Run qwen plugin
    "${qwen_plugin_dir}/main.sh" "$@"
}

# Worker subagent command
_cmd_worker() {
    local worker_plugin_dir="${OML_PLUGINS}/subagents/worker"
    
    if [[ ! -d "$worker_plugin_dir" ]]; then
        echo -e "${RED}Error: Worker plugin not found${NC}"
        return 1
    fi
    
    # Run worker plugin
    "${worker_plugin_dir}/main.sh" "$@"
}

# MCPs management command - Platform-aware
_cmd_mcps() {
    local service="${1:-}"
    shift || true
    
    local platform
    platform="$(_oml_platform_label)"

    case "$service" in
        context7)
            local context7_plugin_dir="${OML_PLUGINS}/mcps/context7"
            if [[ -d "$context7_plugin_dir" && -x "${context7_plugin_dir}/main.sh" ]]; then
                "${context7_plugin_dir}/main.sh" "$@"
            else
                echo -e "${RED}Context7 MCP plugin not found${NC}"
                echo "You can create it with: oml plugins create context7 mcps"
                return 1
            fi
            ;;
        grep-app)
            local grep_app_plugin_dir="${OML_PLUGINS}/mcps/grep-app"
            if [[ -d "$grep_app_plugin_dir" && -x "${grep_app_plugin_dir}/main.sh" ]]; then
                "${grep_app_plugin_dir}/main.sh" "$@"
            else
                echo -e "${RED}Grep-App MCP plugin not found${NC}"
                return 1
            fi
            ;;
        websearch)
            # WebSearch is GNU/Linux only (requires Exa API, not available on Termux)
            if [[ "$platform" == "termux" ]]; then
                echo -e "${RED}Error: WebSearch MCP is not available on Termux${NC}"
                echo "WebSearch requires Exa API which is only supported on GNU/Linux."
                return 1
            fi
            local websearch_plugin_dir="${OML_PLUGINS}/mcps/websearch"
            if [[ -d "$websearch_plugin_dir" && -x "${websearch_plugin_dir}/main.sh" ]]; then
                "${websearch_plugin_dir}/main.sh" "$@"
            else
                echo -e "${RED}WebSearch MCP plugin not found${NC}"
                echo "Run: bash ${OML_ROOT}/plugins/mcps/websearch/scripts/post-install.sh"
                return 1
            fi
            ;;
        list)
            echo "Available MCP services:"
            echo "  context7  - Context7 documentation service"
            echo "  grep-app  - Code search service (GitHub/StackOverflow)"
            if [[ "$platform" != "termux" ]]; then
                echo "  websearch - Web search service (Exa AI) [GNU/Linux only]"
            fi
            ;;
        help|--help|-h|"")
            cat <<EOF
OML MCP Services

Platform: ${platform}

Usage: oml mcps <service> <action>

Services:
  context7    Context7 documentation service (all platforms)
  grep-app    Code search service (all platforms)
EOF
            if [[ "$platform" != "termux" ]]; then
                cat <<EOF
  websearch   Web search via Exa AI (GNU/Linux only)
EOF
            fi
            cat <<EOF

Examples:
  oml mcps context7 enable --mode local
  oml mcps context7 status
  oml mcps grep-app search "python function" --ext py
EOF
            if [[ "$platform" != "termux" ]]; then
                cat <<EOF
  oml mcps websearch search "OpenAI API documentation"
EOF
            fi
            cat <<EOF
  oml mcps list
EOF
            ;;
        *)
            echo "Unknown MCP service: $service"
            echo "Use 'oml mcps help' for usage"
            return 1
            ;;
    esac
}

# Main entry point
main() {
    local cmd="${1:-help}"
    shift || true

    case $cmd in
        build)   _cmd_build "$@" ;;
        hotfix)  _cmd_hotfix "$@" ;;
        doc)     _cmd_doc "$@" ;;
        opencode) _cmd_opencode "$@" ;;
        plugins) _cmd_plugins "$@" ;;
        worker)  _cmd_worker "$@" ;;
        mcps)    _cmd_mcps "$@" ;;
        qwen)    _cmd_qwen "$@" ;;
        platform) _cmd_platform "$@" ;;
        version|--version|-v) _cmd_version ;;
        help|--help|-h) _show_help ;;
        *)
            # Try to find a plugin with this name
            local plugin_dir
            plugin_dir="$(oml_find_plugin "$cmd" 2>/dev/null || true)"
            if [[ -n "$plugin_dir" && -x "${plugin_dir}/main.sh" ]]; then
                "${plugin_dir}/main.sh" "$@"
            else
                echo -e "${RED}Unknown command: $cmd${NC}"
                _show_help
                exit 1
            fi
            ;;
    esac
}

main "$@"
