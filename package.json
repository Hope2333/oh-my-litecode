{
  "name": "oh-my-litecode",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "packages/plugins/mcps/*",
    "packages/*", "packages/plugins/subagents/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "architecture:check": "node ./scripts/check-architecture-contract.mjs",
    "test": "npm run architecture:check && turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
