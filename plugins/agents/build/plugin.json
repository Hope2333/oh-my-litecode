{
  "name": "build",
  "version": "1.0.0",
  "type": "agent",
  "description": "构建代理 - 项目构建、清理、状态和日志管理",
  "author": "OML Team",
  "license": "MIT",
  "platforms": ["termux", "gnu-linux"],
  "dependencies": ["bash", "make", "python3"],
  "env": {
    "OML_BUILD_VERBOSE": {"required": false, "default": "false"},
    "OML_BUILD_PARALLEL": {"required": false, "default": "auto"},
    "OML_BUILD_LOG_DIR": {"required": false, "default": ""}
  },
  "commands": [
    {
      "name": "project",
      "description": "构建项目 (build project [PROJECT] [OPTIONS])",
      "handler": "main.sh project"
    },
    {
      "name": "clean",
      "description": "清理构建产物 (build clean [PROJECT])",
      "handler": "main.sh clean"
    },
    {
      "name": "status",
      "description": "查看构建状态 (build status [PROJECT])",
      "handler": "main.sh status"
    },
    {
      "name": "logs",
      "description": "查看构建日志 (build logs [PROJECT] [OPTIONS])",
      "handler": "main.sh logs"
    }
  ],
  "hooks": {
    "post_install": "scripts/post-install.sh",
    "pre_uninstall": "scripts/pre-uninstall.sh"
  }
}
