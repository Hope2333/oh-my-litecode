{
  "name": "qwen-oauth-switcher",
  "version": "1.0.0",
  "type": "utility",
  "description": "Qwen OAuth account switcher - Manage multiple free accounts via config file switching",
  "author": "OML Team",
  "license": "MIT",
  "platforms": ["termux", "gnu-linux"],
  "dependencies": ["bash", "python3", "jq"],
  "env": {
    "QWEN_OAUTH_DIR": {
      "required": false,
      "default": "~/.oml/qwen-oauth",
      "description": "OAuth config storage directory"
    },
    "QWEN_CONFIG_DIR": {
      "required": false,
      "default": "~/.local/home/qwenx/.qwen",
      "description": "Qwen config directory"
    }
  },
  "commands": [
    {
      "name": "list",
      "description": "List all OAuth accounts",
      "handler": "main.sh list"
    },
    {
      "name": "add",
      "description": "Add new OAuth account (login to get config)",
      "handler": "main.sh add"
    },
    {
      "name": "use",
      "description": "Switch to specified account",
      "handler": "main.sh use"
    },
    {
      "name": "current",
      "description": "Show current active account",
      "handler": "main.sh current"
    },
    {
      "name": "remove",
      "description": "Remove OAuth account",
      "handler": "main.sh remove"
    },
    {
      "name": "rotate",
      "description": "Rotate to next account",
      "handler": "main.sh rotate"
    },
    {
      "name": "backup",
      "description": "Backup current config",
      "handler": "main.sh backup"
    },
    {
      "name": "restore",
      "description": "Restore from backup",
      "handler": "main.sh restore"
    }
  ],
  "features": {
    "multiAccount": true,
    "fileSwitching": true,
    "autoBackup": true,
    "configCopy": true
  }
}
